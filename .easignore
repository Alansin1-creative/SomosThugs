# Local Expo cache — do not upload (tar on EAS failed with Permission denied under .expo/web).
.expo/
**/.expo/

# Web export / Metro output at repo root (not needed for native build; often OneDrive reparse + read-only).
_expo/

# Never bundle dependencies (EAS runs npm ci on the server).
node_modules/

# Web export and bundles — not used for native EAS Build; was inflating archive (~100MB+).
dist-web/
dist-web.zip
*.zip

# API runs on Render; app does not import server code. Excludes server/node_modules from upload.
server/

# Accidental nested installs under assets
assets/node_modules/
