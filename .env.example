# Copia a .env y rellena. Las EXPO_PUBLIC_* se incrustan al hacer npm run build:web:production.

# API producción (Railway). Opcional si usas la URL por defecto en src/config/api.js
# EXPO_PUBLIC_API_PRODUCTION_URL=https://somosthugs-production.up.railway.app

# Solo desarrollo web en localhost: backend local (por defecto http://localhost:4000)
# EXPO_PUBLIC_API_URL_WEB=http://localhost:4000

# App nativa: forzar URL del API (por defecto = producción)
# EXPO_PUBLIC_API_URL_NATIVE=

# Google Maps en cliente (embed / AdminEventos web). El server usa GOOGLE_MAPS_API_KEY en Railway.
# EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# AdSense (solo se muestra en web con cliente + slot)
# EXPO_PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXX
# EXPO_PUBLIC_ADSENSE_SLOT=XXXXXXXXXX
