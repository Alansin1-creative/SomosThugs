# API del backend (Expo / app). Ajustá host y puerto a tu entorno.

# URL pública del API en producción (sin barra final).
# Ejemplo: https://api.tudominio.com
EXPO_PUBLIC_API_PRODUCTION_URL=

# Desarrollo web: suele ser el mismo host donde corre Express.
# Ejemplo: http://localhost:4000
EXPO_PUBLIC_API_URL_WEB=

# App nativa (emulador/dispositivo): IP de tu PC en la red local o túnel.
# Ejemplo: http://192.168.1.10:4000
EXPO_PUBLIC_API_URL_NATIVE=

# --- Google Sign-In (ESTE archivo, raíz del repo: lo lee Metro/EAS y se embebe en la app) ---
# NO alcanza con poner solo GOOGLE_* en server/.env: eso es solo para el backend al verificar el id_token.
# Cliente OAuth tipo Android (package com.somosthugs.app + SHA-1 del keystore de EAS para builds de tienda).
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
# Opcional (iOS / TestFlight).
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
# Cliente OAuth tipo Web (obligatorio para login con Google en navegador / export web).
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
#
# En server/.env van aparte GOOGLE_CLIENT_ID y GOOGLE_WEB_CLIENT_ID para el API (verificación del token).


# Expo Push (Android/iOS APK o build EAS). UUID del proyecto en expo.dev.
# Obtenelo con: npx eas-cli@latest init   (o en https://expo.dev → tu proyecto → Project ID)
# Sin esto, getExpoPushTokenAsync puede fallar en builds de producción.
EXPO_PUBLIC_EAS_PROJECT_ID=

# Misma clave que GOOGLE_MAPS_API_KEY en server/.env si usás mapas en el cliente.
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# AdSense solo en build web (expo export --platform web). En nativo: AdMob.
# Cliente AdSense (ca-pub-…). También sirve para la meta google-adsense-account al exportar web.
EXPO_PUBLIC_ADSENSE_CLIENT=
# Opcional: unidad display. Sin esto podés usar solo anuncios automáticos en la consola AdSense.
EXPO_PUBLIC_ADSENSE_SLOT=

# --- Web Push (opcional, solo si usás notificaciones escritorio en la app web) ---
# Debe ser EXACTAMENTE la misma cadena que WEB_PUSH_PUBLIC_KEY en server/.env (la Public Key de npx web-push).
# Si lo dejás vacío, la app igual puede suscribirse pidiendo la clave al API (/auth/web-push/public-key).
EXPO_PUBLIC_VAPID_PUBLIC_KEY=
