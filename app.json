{
  "expo": {
    "name": "Somos Thugs",
    "slug": "somos-thugs",
    "version": "1.0.0",
    "scheme": "somosthugs",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a1a"
    },
    "android": {
      "package": "com.somosthugs.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#1a1a1a"
      },
      "permissions": [
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.somosthugs.app",
      "supportsTablet": true
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Cámara para subir fotos."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Ubicación para el mapa de eventos."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#00dc57",
          "defaultChannel": "default"
        }
      ],
      "expo-asset",
      "expo-web-browser",
      "expo-video",
      "expo-audio"
    ],
    "web": {
      "favicon": "./assets/favicon.png",
      "name": "Somos Thugs",
      "shortName": "Somos Thugs",
      "lang": "es",
      "themeColor": "#0d0d0d",
      "backgroundColor": "#0d0d0d"
    },
    "extra": {
      "eas": {
        "projectId": "4febf8d7-ad14-4d48-9641-974ccded68a3"
      },
      "router": {}
    },
    "owner": "alan2869"
  }
}
