{
  "expo": {
    "name": "Somos Thugs",
    "slug": "somos-thugs",
    "version": "1.0.0",
    "scheme": "somosthugs",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a1a"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Cámara para subir fotos."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Ubicación para el mapa de eventos."
        }
      ],
      "expo-notifications",
      "expo-asset",
      "expo-web-browser",
      "expo-video"
    ],
    "web": {
      "favicon": "./assets/logothugs.png",
      "name": "Somos Thugs",
      "shortName": "Somos Thugs",
      "lang": "es",
      "themeColor": "#0d0d0d",
      "backgroundColor": "#0d0d0d"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4febf8d7-ad14-4d48-9641-974ccded68a3"
      }
    },
    "ios": {
      "bundleIdentifier": "com.alan2869.somosthugs",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    }
  }
}
