    "@react-navigation/native-stack": "^7.0.0",
    "expo": "~54.0.0",
    "expo-asset": "~12.0.12",
    "expo-auth-session": "~7.0.10",
    "expo-blur": "~15.0.8",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-device": "^55.0.10",
    "expo-document-picker": "~14.0.4",
    "expo-file-system": "~19.0.21",
    "expo-image-picker": "~17.0.10",
    "expo-linking": "~8.0.11",
