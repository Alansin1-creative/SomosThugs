  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "start:clean": "expo start --clear",
    "web": "expo start --web --clear",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "export:web": "npx expo export --platform web --output-dir dist-web",
