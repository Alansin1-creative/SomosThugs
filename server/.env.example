# === Obligatorio en producción ===
# Cadena de conexión MongoDB (Atlas, local, etc.)
MONGODB_URI=mongodb://localhost:27017/somos-thugs

# Firma de los JWT (login / sesión). Generá una cadena larga y aleatoria.
# Ejemplo (NO uses este valor en prod): mi_clave_super_secreta_de_al_menos_32_caracteres
JWT_SECRET=

# === Servidor HTTP ===
PORT=4000

# Orígenes permitidos por CORS, separados por coma (sin espacios extra).
# Local + web + app:
# CORS_ORIGINS=http://localhost:8081,http://localhost:19006,https://tudominio.com
CORS_ORIGINS=

# === Login con Google (opcional; si falta, login-google no valida tokens) ===
# IDs de cliente OAuth de Google Cloud (Android/iOS vs Web).
GOOGLE_CLIENT_ID=
GOOGLE_WEB_CLIENT_ID=

# === Mapas (opcional; rutas que usan mapas del servidor) ===
GOOGLE_MAPS_API_KEY=

# === Firebase Storage (opcional; imágenes/vídeos en bucket, no se pierden en redeploy) ===
# Bucket del proyecto (el tuyo es somosthugs → gs://somosthugs.firebasestorage.app).
# Si lo omitís, el código usa por defecto: somosthugs.firebasestorage.app
FIREBASE_STORAGE_BUCKET=somosthugs.firebasestorage.app

# Elegí UNA de las dos formas de cuenta de servicio (JSON descargado desde Firebase Console
# → Configuración del proyecto → Cuentas de servicio → Generar nueva clave privada):

# Recomendado en Render/hosting: todo el JSON en una sola línea Base64.
# PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes("ruta\clave.json")) | Set-Clipboard
FIREBASE_SERVICE_ACCOUNT_BASE64=

# Alternativa (local): JSON minificado en una sola línea (cuidado con comillas en el private_key).
# FIREBASE_SERVICE_ACCOUNT_JSON=
