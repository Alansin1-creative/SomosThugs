# === Obligatorio en producción ===
# Cadena de conexión MongoDB (Atlas, local, etc.)
MONGODB_URI=mongodb://localhost:27017/somos-thugs

# Firma de los JWT (login / sesión). Generá una cadena larga y aleatoria.
# Ejemplo (NO uses este valor en prod): mi_clave_super_secreta_de_al_menos_32_caracteres
JWT_SECRET=

# === Servidor HTTP ===
PORT=4000

# Orígenes permitidos por CORS, separados por coma (sin espacios extra).
# Local + web + app:
# CORS_ORIGINS=http://localhost:8081,http://localhost:19006,https://tudominio.com
CORS_ORIGINS=

# === Login con Google (opcional; si falta, login-google no valida tokens) ===
# IDs de cliente OAuth de Google Cloud (Android/iOS vs Web).
GOOGLE_CLIENT_ID=
GOOGLE_WEB_CLIENT_ID=

# === Mapas (recomendado si usás Admin → Eventos: autocompletado de lugar vía /maps/*) ===
# Clave de servidor (restricción por IP de Render o sin restricción HTTP-referrer).
# Places API (Legacy) o la que use tu proyecto para autocomplete + details.
GOOGLE_MAPS_API_KEY=

# === Firebase Storage (opcional; imágenes/vídeos en bucket, no se pierden en redeploy) ===
# Bucket del proyecto (el tuyo es somosthugs → gs://somosthugs.firebasestorage.app).
# Si lo omitís, el código usa por defecto: somosthugs.firebasestorage.app
FIREBASE_STORAGE_BUCKET=somosthugs.firebasestorage.app

# Elegí UNA de las dos formas de cuenta de servicio (JSON descargado desde Firebase Console
# → Configuración del proyecto → Cuentas de servicio → Generar nueva clave privada):

# Recomendado en Render/hosting: todo el JSON en una sola línea Base64.
# PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes("ruta\clave.json")) | Set-Clipboard
FIREBASE_SERVICE_ACCOUNT_BASE64=

# Alternativa (local): JSON minificado en una sola línea (cuidado con comillas en el private_key).
# FIREBASE_SERVICE_ACCOUNT_JSON=

# === Web Push (notificaciones del navegador: campana / Perfil en la web) ===
# Copiá estas líneas a tu archivo server/.env (no subas .env a git) y completá los valores.
#
# 1) En una terminal ejecutá:  npx web-push generate-vapid-keys
# 2) Pegá la salida en los campos de abajo (cada clave es UNA sola línea, sin comillas).
#
# --- Campos obligatorios para que "Activar" notificaciones web funcione ---
# Public Key (la que empieza con B...): va al cliente y al endpoint GET /auth/web-push/public-key
WEB_PUSH_PUBLIC_KEY=
# Private Key (secreta, solo servidor; nunca en el front ni en Git)
WEB_PUSH_PRIVATE_KEY=
# Contacto del emisor VAPID (obligatorio por especificación). Usá tu correo real.
# Ejemplo: mailto:alan@tudominio.com
WEB_PUSH_SUBJECT=
#
# Comprobación: con el servidor arrancado, abrí en el navegador:
#   http://localhost:PORT/auth/web-push/public-key
# Debe responder JSON {"publicKey":"B..."}. Si ves 503, faltan claves o reiniciá el server.
